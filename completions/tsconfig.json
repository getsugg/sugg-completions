{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": [],
    "paths": {}
  },
  "include": ["**/*.ts", "**/*.js", ".sugg/sugg.d.ts", ".sugg/i18n.d.ts"],
  "exclude": ["node_modules"]
}
